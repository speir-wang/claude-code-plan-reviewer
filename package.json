{
  "name": "claude-code-plan-reviewer",
  "version": "1.0.0",
  "description": "Interactive browser-based plan review for Claude Code via MCP",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "plan-reviewer-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/bundle-browser.js",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^8.0.4",
    "express": "^5.2.1",
    "marked": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "esbuild": "^0.28.0",
    "playwright": "^1.56.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
